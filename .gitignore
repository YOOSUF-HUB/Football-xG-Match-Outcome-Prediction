# --- Environments ---
.venv/
venv/
env/

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- Data ---
# Raw and processed data are reproducible from StatsBomb Open Data via src/,
# and are far too large for git. Keep the folders, ignore the contents.
data/raw/*
data/processed/*
!data/**/.gitkeep

# --- Model artifacts ---
models/*
!models/.gitkeep

# --- Generated figures ---
# Regenerated by the notebooks, so ignored by default -- except the ones the
# README embeds, which must be tracked for it to render on GitHub. They are
# tracked in place rather than copied to a docs/ folder so there is one source
# of truth: re-running the notebook updates them and git shows the diff.
reports/figures/*
!reports/figures/.gitkeep
!reports/figures/class_balance.png
!reports/figures/distance_angle_signal.png
!reports/figures/pre_shot_flags.png
!reports/figures/shot_map.png
!reports/figures/statsbomb_xg_benchmark.png
!reports/figures/volume_vs_conversion.png

# --- OS / editor ---
.DS_Store
.vscode/
.idea/
